# Tremor 3.18.7 declares a React ^18 peer, but it runs on React 19: its only
# interactive dependency, @headlessui/react 2.2.0, supports React 19. This flag
# lets the approved dependency set install cleanly and reproducibly (locally and
# on Vercel) under React 19 / Next 16. See DECISIONS.md D22 and the B1 Tremor
# flag in SESSION_LOG.md.
#
# Note: this file is intentionally machine-agnostic. The corporate-network CA
# workaround (NODE_OPTIONS=--use-system-ca) is NOT set here because it is
# specific to one machine; it lives in the README and SESSION_LOG, not the repo.
legacy-peer-deps=true
